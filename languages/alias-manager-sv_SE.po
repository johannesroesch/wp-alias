#. Plugin Name of the plugin
msgid "Alias Manager"
msgstr "Alias Manager"

#. Description of the plugin
msgid "Manage URL aliases for WordPress pages with automatic 301 redirects."
msgstr "Hantera URL-alias för WordPress-sidor med automatiska 301-omdirigeringar."

#: admin/class-alias-admin.php
msgid "Alias deleted."
msgstr "Alias raderat."

#: admin/class-alias-admin.php
msgid "Alias and target URL must not be empty."
msgstr "Alias och mål-URL får inte vara tomma."

#: admin/class-alias-admin.php
msgid "Alias updated."
msgstr "Alias uppdaterat."

#: admin/class-alias-admin.php
msgid "Update failed. The alias slug may already be in use."
msgstr "Uppdateringen misslyckades. Alias-slug kan redan vara i användning."

#: admin/class-alias-admin.php
msgid "Alias added."
msgstr "Alias tillagt."

#: admin/class-alias-admin.php
msgid "Error: Alias slug already in use or invalid input."
msgstr "Fel: Alias-slug används redan eller ogiltigt indata."

#: admin/class-alias-admin.php
msgid "Update Alias"
msgstr "Uppdatera alias"

#: admin/class-alias-admin.php
msgid "Add Alias"
msgstr "Lägg till alias"

#: admin/class-alias-admin.php
msgid "Edit Alias"
msgstr "Redigera alias"

#: admin/class-alias-admin.php
msgid "Add New Alias"
msgstr "Lägg till nytt alias"

#: admin/class-alias-admin.php
msgid "Alias Path"
msgstr "Alias-sökväg"

#: admin/class-alias-admin.php
msgid "Enter the slug only, e.g. \"my-page\" for example.com/my-page"
msgstr "Ange bara slug, t.ex. \"min-sida\" för example.com/min-sida"

#: admin/class-alias-admin.php
msgid "Select Page"
msgstr "Välj sida"

#: admin/class-alias-admin.php
msgid "&mdash; Select a page &mdash;"
msgstr "&mdash; Välj en sida &mdash;"

#: admin/class-alias-admin.php
msgid "Automatically fills in the target URL field."
msgstr "Fyller automatiskt i mål-URL-fältet."

#: admin/class-alias-admin.php
msgid "Target URL"
msgstr "Mål-URL"

#: admin/class-alias-admin.php
msgid "Full URL of the target. Visitors will be redirected via 301."
msgstr "Fullständig URL för målet. Besökare omdirigeras via 301."

#: admin/class-alias-admin.php
msgid "Cancel"
msgstr "Avbryt"

#: admin/class-alias-admin.php
msgid "Existing Aliases"
msgstr "Befintliga alias"

#: admin/class-alias-admin.php
msgid "No aliases have been added yet."
msgstr "Inga alias har lagts till ännu."

#: admin/class-alias-admin.php
msgid "Created"
msgstr "Skapad"

#: admin/class-alias-admin.php
msgid "Actions"
msgstr "Åtgärder"

#: admin/class-alias-admin.php
msgid "Edit"
msgstr "Redigera"

#: admin/class-alias-admin.php
msgid "Really delete this alias?"
msgstr "Vill du verkligen radera detta alias?"

#: admin/class-alias-admin.php
msgid "Delete"
msgstr "Radera"
