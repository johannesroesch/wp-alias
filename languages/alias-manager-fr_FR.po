#. Plugin Name of the plugin
msgid "Alias Manager"
msgstr "Alias Manager"

#. Description of the plugin
msgid "Manage URL aliases for WordPress pages with automatic 301 redirects."
msgstr "Gérez les alias d'URL pour les pages WordPress avec des redirections 301 automatiques."

#: admin/class-alias-admin.php
msgid "Alias deleted."
msgstr "Alias supprimé."

#: admin/class-alias-admin.php
msgid "Alias and target URL must not be empty."
msgstr "L'alias et l'URL cible ne peuvent pas être vides."

#: admin/class-alias-admin.php
msgid "Alias updated."
msgstr "Alias mis à jour."

#: admin/class-alias-admin.php
msgid "Update failed. The alias slug may already be in use."
msgstr "Échec de la mise à jour. Le slug de l'alias est peut-être déjà utilisé."

#: admin/class-alias-admin.php
msgid "Alias added."
msgstr "Alias ajouté."

#: admin/class-alias-admin.php
msgid "Error: Alias slug already in use or invalid input."
msgstr "Erreur : le slug d'alias est déjà utilisé ou la saisie est invalide."

#: admin/class-alias-admin.php
msgid "Update Alias"
msgstr "Mettre à jour l'alias"

#: admin/class-alias-admin.php
msgid "Add Alias"
msgstr "Ajouter un alias"

#: admin/class-alias-admin.php
msgid "Edit Alias"
msgstr "Modifier l'alias"

#: admin/class-alias-admin.php
msgid "Add New Alias"
msgstr "Ajouter un nouvel alias"

#: admin/class-alias-admin.php
msgid "Alias Path"
msgstr "Chemin de l'alias"

#: admin/class-alias-admin.php
msgid "Enter the slug only, e.g. \"my-page\" for example.com/my-page"
msgstr "Entrez uniquement le slug, p. ex. \"ma-page\" pour example.com/ma-page"

#: admin/class-alias-admin.php
msgid "Select Page"
msgstr "Sélectionner une page"

#: admin/class-alias-admin.php
msgid "&mdash; Select a page &mdash;"
msgstr "&mdash; Sélectionner une page &mdash;"

#: admin/class-alias-admin.php
msgid "Automatically fills in the target URL field."
msgstr "Remplit automatiquement le champ URL cible."

#: admin/class-alias-admin.php
msgid "Target URL"
msgstr "URL cible"

#: admin/class-alias-admin.php
msgid "Full URL of the target. Visitors will be redirected via 301."
msgstr "URL complète de la cible. Les visiteurs seront redirigés via 301."

#: admin/class-alias-admin.php
msgid "Cancel"
msgstr "Annuler"

#: admin/class-alias-admin.php
msgid "Existing Aliases"
msgstr "Alias existants"

#: admin/class-alias-admin.php
msgid "No aliases have been added yet."
msgstr "Aucun alias n'a encore été ajouté."

#: admin/class-alias-admin.php
msgid "Created"
msgstr "Créé le"

#: admin/class-alias-admin.php
msgid "Actions"
msgstr "Actions"

#: admin/class-alias-admin.php
msgid "Edit"
msgstr "Modifier"

#: admin/class-alias-admin.php
msgid "Really delete this alias?"
msgstr "Voulez-vous vraiment supprimer cet alias ?"

#: admin/class-alias-admin.php
msgid "Delete"
msgstr "Supprimer"
